{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Hugo: Check Environment",
            "type": "shell",
            "command": "which hugo || (echo 'Hugo not found. Please make sure Hugo is installed and in your PATH.' && exit 1)",
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Hugo: Start Server",
            "type": "shell",
            "command": "hugo server --bind=0.0.0.0 --appendPort=false --liveReloadPort=443 -D",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$",
                    "file": 0,
                    "location": 1,
                    "message": 2
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Building sites.*$",
                    "endsPattern": "^.*Web Server is available.*$"
                }
            }
        }
    ]
}