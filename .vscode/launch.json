{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Hugo Server",
            "type": "pwa-node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/.bin/hugo",
            "args": [
                "server",
                "--bind=0.0.0.0",
                "--appendPort=false",
                "--baseURL=/",
                "--liveReloadPort=443",
                "-D"
            ],
            "console": "integratedTerminal",
            "preLaunchTask": "Hugo: Check Environment"
        }
    ]
}